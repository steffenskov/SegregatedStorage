<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <Description>Extension to SegregatedStorage adding support for MongoDB for storing metadata</Description>
        <PackageProjectUrl>https://github.com/steffenskov/SegregatedStorage.MongoFileRepository</PackageProjectUrl>
        <PackageTags>storage, segregation</PackageTags>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <RootNamespace>SegregatedStorage</RootNamespace>
    </PropertyGroup>
    <ItemGroup>
        <None Include="../../../README.md" Pack="true" PackagePath="\"/>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="MongoDB.Driver"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\SegregatedStorage\SegregatedStorage.csproj"/>
    </ItemGroup>

</Project>
